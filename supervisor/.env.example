# cache_supervisor configuration
# Copy to .env and adjust. All values are optional unless noted.
# Comma-separated fields (EXPECTED_USERS, OIDC_AUDIENCES) accept either
# "a,b,c" or a JSON list '["a","b","c"]'.

# --- General ---------------------------------------------------------------
# local | staging | production.
ENVIRONMENT=local
PROJECT_NAME=lclstream_cache_supervisor
API_V1_STR=/api/v1

# --- Server / TLS ----------------------------------------------------------
# Bind address for the supervisor API.
HOST=0.0.0.0
PORT=8000
# Set BOTH to serve over HTTPS (uvicorn in-process TLS); leave unset for HTTP.
# SSL_CERTFILE=/path/to/server.crt
# SSL_KEYFILE=/path/to/server.key
# mTLS: require clients to present a cert signed by this CA (self-signed is fine
# for a single known client). Needs server TLS above.
# SSL_CA_CERTS=/path/to/ca.crt
# REQUIRE_CLIENT_CERT=false

# --- Database --------------------------------------------------------------
# SQLite file path; accessed asynchronously via aiosqlite.
SQLITE_PATH=cache_supervisor.sqlite

# --- Authentication / Authorization ---------------------------------------
# REQUIRED: verified emails allowed to use the service. Empty = deny everyone.
EXPECTED_USERS=

# REQUIRED: OIDC issuer URL used to validate bearer tokens.
OIDC_ISSUER_URL=
# JWKS endpoint; defaults to "<OIDC_ISSUER_URL>/keys" if left unset.
# OIDC_JWKS_URI=
# Expected token audience(s).
OIDC_AUDIENCES=

# --- Cache process management ----------------------------------------------
# Path to the fastcache executable; bare name = resolved via PATH.
FASTCACHE_BINARY=lclstream-fastcache
# Directory where per-cache config/log files are written.
RUN_DIR=run
# Grace period (seconds) before escalating SIGTERM to SIGKILL on shutdown.
SHUTDOWN_GRACE_SECONDS=5.0
